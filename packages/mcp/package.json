{
  "name": "@purmemo/mcp",
  "version": "0.1.0",
  "description": "Reference MCP server for AMP — expose AI memories via Model Context Protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "purmemo-mcp": "./dist/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/server.ts src/index.ts --format esm --dts",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@purmemo/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["amp", "ai-memory-protocol", "mcp", "model-context-protocol", "memory", "purmemo"],
  "license": "Apache-2.0",
  "homepage": "https://github.com/purmemo/purmemo-amp",
  "repository": {
    "type": "git",
    "url": "https://github.com/purmemo/purmemo-amp"
  }
}
