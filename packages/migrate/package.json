{
  "name": "@purmemo.ai/migrate",
  "version": "0.1.3",
  "description": "CLI tool to migrate AI conversations to AMP format — supports ChatGPT, Claude, Gemini, Cursor",
  "type": "module",
  "bin": {
    "purmemo-migrate": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@purmemo.ai/converters": "workspace:*",
    "@purmemo.ai/schema": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "amp",
    "ai-memory-protocol",
    "chatgpt",
    "migration",
    "cli",
    "portability",
    "purmemo"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/purmemo-ai/purmemo-amp",
  "repository": {
    "type": "git",
    "url": "https://github.com/purmemo-ai/purmemo-amp"
  }
}
